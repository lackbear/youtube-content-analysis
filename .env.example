# ─────────────────────────────────────────────────────────────────────────────
# .env.example  — template for environment variables the container needs.
#
# Copy this file to `.env` and fill in real values. `.env` is gitignored
# and .dockerignored, so your actual API key never leaves your machine.
#
#   cp .env.example .env
#   # then edit .env and set your real key
#
# Compose reads `.env` automatically; the collector reads YOUTUBE_API_KEY
# from its process environment via os.getenv().
# ─────────────────────────────────────────────────────────────────────────────

# Your YouTube Data API v3 key. Get one at:
#   https://console.cloud.google.com/apis/credentials
# Restrict it to the YouTube Data API v3 and to your IP if you can.
YOUTUBE_API_KEY=replace_me_with_your_real_key

# Host user/group IDs — passed to the Dockerfile as build args so the
# container's non-root user matches your host user. Avoids the classic
# "container writes root-owned files into my bind-mounted folder" bug.
#
# On WSL2/Linux, find yours with:  id -u   and   id -g
# On macOS with Docker Desktop, leave the defaults (1000/1000) — the VM
# handles UID translation for you.
UID=1000
GID=1000

# Airflow's official image expects its own UID (50000 by default). Changing
# this only matters on native Linux — on Windows/WSL2/macOS you can leave
# the default. Used by docker-compose.yml for the three airflow services.
AIRFLOW_UID=50000
